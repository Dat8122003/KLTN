# Server config - mau vi du. Copy thanh .env roi dien gia tri that.
# File .env da duoc .gitignore lo tru, khong commit.

# Port HTTP (mac dinh 80 neu khong dat)
PORT=80

# URL public de frontend truy cap
API_URL=http://localhost:80
WS_URL=ws://localhost:80

# Secret cho JWT (dat chuoi dai >= 32 ky tu, random)
JWT_SECRET=change-me-to-a-long-random-string-32+chars

# Tai khoan admin mac dinh (se duoc hash bang bcrypt khi server khoi dong)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
